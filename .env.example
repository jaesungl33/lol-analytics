# Copy this to .env and fill in values. Never commit .env.

# ── Data source ──────────────────────────────────────────────────────────────
# true  → FixtureRiotClient (sample data, no key needed)
# false → HttpRiotClient (live Riot API, requires RIOT_API_KEY)
USE_FIXTURES=true

# Player used by the legacy POST /api/ingest endpoint.
# In fixtures mode this must match a key in fixtures/sample_matches.json.
HARDCODED_RIOT_ID=SamplePlayer#NA1

# ── Riot API (only used when USE_FIXTURES=false) ──────────────────────────────
# Get a dev key at https://developer.riotgames.com/ (expires every 24h).
# Apply for a Production Application key for a permanent deployment.
RIOT_API_KEY=
RIOT_REGION=americas            # americas | asia | europe

# ── Database ─────────────────────────────────────────────────────────────────
# Railway / Render set this automatically when you add a Postgres plugin.
DATABASE_URL=postgresql+psycopg2://lol:lol@localhost:5432/lol

# ── Rate limiting (Milestone 2) ───────────────────────────────────────────────
# Riot dev-key defaults. Adjust if you have a production key with higher limits.
RATE_LIMIT_PER_SECOND=20
RATE_LIMIT_PER_TWO_MIN=100
RATE_LIMIT_WINDOW_SECONDS=120

# 429 back-off: exponential, base * 2^attempt, capped, up to max_retries tries.
HTTP_MAX_RETRIES=3
BACKOFF_BASE_SECONDS=0.5
BACKOFF_CAP_SECONDS=8.0

# How long account look-ups and computed stats stay cached (seconds).
CACHE_TTL_SECONDS=300

# ── LLM coaching (Milestone 3) ───────────────────────────────────────────────
# "stub"   → deterministic offline coach, no key needed (default)
# "openai" → real LLM via OpenAI-compatible endpoint, requires OPENAI_API_KEY
COACH_PROVIDER=stub

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
COACH_MODEL=gpt-4o-mini
